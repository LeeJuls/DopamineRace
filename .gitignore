# =====================
# Unity .gitignore
# DopamineRace Project

# 로컬 환경마다 경로가 다른 설정 파일
.mcp.json

# 잘못 생성된 중첩 clone (GitHub Desktop 오설정으로 생성됨)
/DopamineRace/

# Unity 자동 생성 폴더 (절대 올리면 안 됨)
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/
# IDE 설정
/.vscode/
/.idea/
/.vs/
# Visual Studio / Rider 자동 생성 파일
*.csproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
# Unity3D 자동 생성
*.pidb.meta
*.pdb.meta
*.mdb.meta
# OS 자동 생성
.DS_Store
Thumbs.db
desktop.ini
# Crash Reports
sysinfo.txt
crashlytics-build.properties
# Asset Store 캐시
/[Aa]ssets/AssetStoreTools*
# 백업/압축 파일 (zip 등)
*.zip
*.rar
*.7z
*.unitypackage
# Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*
# TextMeshPro (필요시 주석 해제)
# /[Aa]ssets/TextMesh*Pro/
# Recordings (Unity Recorder)
/[Rr]ecordings/
# Claude Code 설정 (로컬 전용, agents/는 공유)
.claude/*
!.claude/agents/
# Scripts 폴더 안에 생성된 Claude Code 설정도 무시
Assets/Scripts/.claude/

# MCP 브릿지 로그
unity_code_mcp_bridge.log

# MCP 재시작 스크립트 (로컬 전용)
Docs/setup/

# C# 언어서버 설정 (로컬 전용)
.lsp.json

# Python 캐시 (MCP STDIO 서버)
__pycache__/
*.pyc

# 백테스팅 로그 (Docs/logs/)
Docs/logs/

# 메모/문서 파일 (선택)
*.txt
!Assets/**/*.txt

# Unity 자동 복구 씬 (크래시 시 자동생성 임시파일)
/[Aa]ssets/[_]Recovery/
/[Aa]ssets/[_]Recovery.meta

# UI 디자이너 파일 전달 임시 폴더 (적용 후 불필요, 히스토리 관리 없음)
/[Aa]ssets/[Dd]esign/[Ii]ncoming/
